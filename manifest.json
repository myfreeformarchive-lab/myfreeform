{
  "manifest_version": 3,
  "name": "Freeform Archive",
  "version": "1.0",
  "description": "A minimalist digital archive for your thoughts.",
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icon_2-16.png",
      "32": "icon_2-32.png",
      "128": "icon_2-128.png"
    }
  },
  "icons": {
    "16": "icon_2-16.png",
    "32": "icon_2-32.png",
    "48": "icon_2-48.png",
    "128": "icon_2-128.png"
  },
  "permissions": ["storage"]
}
